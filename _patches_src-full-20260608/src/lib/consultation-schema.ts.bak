import { z } from "zod";

export const consultationSchema = z.object({
  clientName: z
    .string()
    .min(2, "请输入联系人姓名（至少 2 个字符）")
    .max(20, "姓名不超过 20 个字符"),
  companyName: z
    .string()
    .min(2, "请输入公司名或店铺名")
    .max(100, "公司名或店铺名不超过 100 个字符"),
  phone: z
    .string()
    .regex(/^1[3-9]\d{9}$/, "请输入正确的手机号（11 位数字）"),
  email: z
    .string()
    .email("请输入正确的邮箱地址")
    .optional()
    .or(z.literal("")),
  wechat: z
    .string()
    .max(50, "微信号不超过 50 个字符")
    .optional()
    .or(z.literal("")),
  province: z.string().min(1, "请选择省份"),
  city: z.string().min(1, "请选择城市"),
  industry: z.string().min(1, "请选择所属行业"),
  industryCustom: z
    .string()
    .max(100, "行业描述不超过 100 个字符")
    .optional()
    .or(z.literal("")),
  mainProducts: z
    .string()
    .max(200, "主营产品不超过 200 个字符")
    .optional()
    .or(z.literal("")),
  businessYears: z
    .union([z.number().int().min(0).max(200), z.nan()])
    .optional()
    .transform(v => (typeof v === "number" && !isNaN(v) ? v : undefined)),
  brandHighlight: z
    .string()
    .max(200, "品牌独特点不超过 200 个字符")
    .optional()
    .or(z.literal("")),
  customerProfile: z
    .string()
    .max(200, "客户群体描述不超过 200 个字符")
    .optional()
    .or(z.literal("")),
  existingBrandColor: z
    .string()
    .max(20, "颜色值不超过 20 个字符")
    .optional()
    .or(z.literal("")),
  budgetRange: z.string().optional(),
  brandVision: z
    .string()
    .max(200, "品牌愿景不超过 200 个字符")
    .optional()
    .or(z.literal("")),
  coreValues: z
    .string()
    .max(500, "核心价值不超过 500 个字符")
    .optional()
    .or(z.literal("")),
  targetMarket: z
    .string()
    .max(500, "目标市场不超过 500 个字符")
    .optional()
    .or(z.literal("")),

  brandColors: z.object({
      primary: z.string().optional(),
      secondary: z.string().optional(),
      accent: z.string().optional(),
    }).optional(),

  logoPhilosophy: z
    .string()
    .max(500, "LOGO 设计理念不超过 500 个字符")
    .optional()
    .or(z.literal("")),
  mascotPhilosophy: z
    .string()
    .max(500, "IP 公仔设计理念不超过 500 个字符")
    .optional()
    .or(z.literal("")),
  description: z
    .string()
    .max(1000, "需求描述不超过 1000 个字符")
    .optional()
    .or(z.literal("")),
});

export type ConsultationFormData = z.infer<typeof consultationSchema>;

