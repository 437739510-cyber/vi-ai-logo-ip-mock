# ==== Memory Adapter ====
# "json" = local development (uses public/memory/*.json)
# "supabase" = production (uses Supabase PostgreSQL)
NEXT_PUBLIC_MEMORY_ADAPTER=json

# ==== Mock switch ====
# true=use local mock, false=connect real API
NEXT_PUBLIC_USE_MOCK=true

# ==== AI API — Wanxiang / DashScope ====
# WANXIANG_API_KEY= (optional, falls back to MockProvider if unset)

# ==== Database (fill in when connecting) ====
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==== File Storage (fill in when connecting) ====
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ==== API Proxy (optional, default http://localhost:3000/api) ====
# NEXT_PUBLIC_API_BASE=
