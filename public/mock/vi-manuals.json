        },
        {
          "title": "拉伸或压缩标识",
          "description": "不得任意拉伸、压缩标识的长宽比例。"
        },
        {
          "title": "旋转标识方向",
          "description": "标识方向已经统一设定,不得旋转或翻转。"
        },
        {
          "title": "替换标准字字体",
          "description": "标准字为品牌专属设计,不得替换为其他字体。"
        },
        {
          "title": "添加描边或阴影",
          "description": "不得对标识添加描边、阴影、浮雕等效果。"
        },
        {
          "title": "放入任意轮廓",
          "description": "不得将标识放入任意形状的轮廓或背景框中。"
        },
        {
          "title": "低对比背景使用",
          "description": "避免将蓝色标识直接置于蓝色或深色背景上。"
        },
        {
          "title": "过度作为纹样装饰",
          "description": "不得将标识作为底纹或装饰图案重复使用。"
        }
      ],
      "brandArchitecture": {
        "model": "单一品牌识别体系",
        "rules": "星云科技采用单一品牌识别体系。部门、产品、活动名称不得与主标识绑定生成新组合。联合传播时,星云标识应与合作方标识保持等高。"
      }
